{
  "name": "highlight-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Free, privacy-first web highlighter with sync & review. Open-source Readwise alternative.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "package:chrome": "pnpm build && mkdir -p dist-chrome && cd dist && zip -r ../dist-chrome/highlight-sync.zip .",
    "package:firefox": "pnpm build && web-ext build --source-dir dist --artifacts-dir dist-firefox --overwrite-dest",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:coverage && pnpm build",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:coverage && pnpm run build"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-security": "^3.0.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.4",
    "web-ext": "^8.4.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0"
    },
    "auditConfig": {
      "ignoreCves": [
        "GHSA-mw96-cpmx-2vgc"
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AjayYadavAi/highlight-sync"
  },
  "keywords": [
    "browser-extension",
    "highlighter",
    "readwise-alternative",
    "privacy-first",
    "spaced-repetition",
    "obsidian",
    "notion",
    "anki"
  ]
}
